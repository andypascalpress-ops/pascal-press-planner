# Monday.com API token (from Monday.com → Profile → Developers → API)
MONDAY_API_TOKEN=your_monday_api_token_here

# Monday.com Board ID — set this AFTER running /api/setup-board
# The setup endpoint will return this value
MONDAY_BOARD_ID=

# Anthropic API key (from console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
